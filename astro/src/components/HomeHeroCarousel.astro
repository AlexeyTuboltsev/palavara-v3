---
import { SITE } from '../data/site';
import { ROUTES } from '../data/routes';
import { getManifest } from '../data/imageManifest';
import appStyles from '../components-styles/App.module.scss';

const home = ROUTES.home;
const prefix = SITE.imgPrefix;
const images = home.images || ['home-1'];
const visualTestMode = process.env.VISUAL_TEST_MODE === 'true';

const manifest = visualTestMode ? null : await getManifest();
const initialLqip = manifest?.images[`${images[0]}.jpg`]?.lqip.base64 ?? null;

const buildSet = (base: string, ext: 'avif' | 'webp' | 'jpg') =>
  `${prefix}/${base}-640.${ext} 640w, ${prefix}/${base}-1280.${ext} 1280w, ${prefix}/${base}.${ext} 1920w`;
---

{visualTestMode ? (
  <div
    class={appStyles.backgroundImg}
    style="background-color:#e0e0e0;width:100%;height:100%;position:absolute;top:0;left:0;opacity:1;"
    aria-hidden="true"
  ></div>
) : (
  <>
    {initialLqip && (
      <img
        src={initialLqip}
        alt=""
        aria-hidden="true"
        class={appStyles.backgroundImgLowRes}
      />
    )}
    <picture data-hero data-images={JSON.stringify(images)} data-prefix={prefix}>
      <source srcset={buildSet(images[0], 'avif')} sizes="100vw" type="image/avif" data-source="avif" />
      <source srcset={buildSet(images[0], 'webp')} sizes="100vw" type="image/webp" data-source="webp" />
      <img
        src={`${prefix}/${images[0]}.jpg`}
        srcset={buildSet(images[0], 'jpg')}
        sizes="100vw"
        alt={home.imageAlt || ''}
        loading="eager"
        fetchpriority="high"
        class={appStyles.backgroundImg}
      />
    </picture>
  </>
)}

{!visualTestMode && (
  <script define:vars={{ visibleClass: appStyles.backgroundImgVisible }} is:inline>
    (function () {
      var PERIOD_MS = 5000;
      var pictures = document.querySelectorAll('[data-hero]');
      for (var p = 0; p < pictures.length; p++) {
        (function (picture) {
          var images = JSON.parse(picture.getAttribute('data-images') || '[]');
          var prefix = picture.getAttribute('data-prefix') || '';
          var avifSrc = picture.querySelector('[data-source="avif"]');
          var webpSrc = picture.querySelector('[data-source="webp"]');
          var img = picture.querySelector('img');
          if (!avifSrc || !webpSrc || !img) return;

          function buildSet(base, ext) {
            return prefix + '/' + base + '-640.' + ext + ' 640w, ' +
              prefix + '/' + base + '-1280.' + ext + ' 1280w, ' +
              prefix + '/' + base + '.' + ext + ' 1920w';
          }

          // Initial fade-in once the first image finishes loading.
          function markVisible() { img.classList.add(visibleClass); }
          if (img.complete && img.naturalWidth > 0) markVisible();
          else img.addEventListener('load', markVisible, { once: true });

          if (images.length <= 1) return;

          var i = 0;
          function swap(base) {
            avifSrc.srcset = buildSet(base, 'avif');
            webpSrc.srcset = buildSet(base, 'webp');
            img.srcset = buildSet(base, 'jpg');
            img.src = prefix + '/' + base + '.jpg';
          }
          function preloadAndSwap(base) {
            var pre = new Image();
            pre.sizes = '100vw';
            pre.srcset = buildSet(base, 'jpg');
            pre.onload = function () { swap(base); };
            pre.onerror = function () { swap(base); };
            pre.src = prefix + '/' + base + '.jpg';
          }

          setInterval(function () {
            i = (i + 1) % images.length;
            preloadAndSwap(images[i]);
          }, PERIOD_MS);
        })(pictures[p]);
      }
    })();
  </script>
)}
