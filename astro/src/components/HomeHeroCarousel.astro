---
import { SITE } from '../data/site';
import { ROUTES } from '../data/routes';

const home = ROUTES.home;
const prefix = SITE.imgPrefix;
const images = home.images || ['home-1'];

const buildSet = (base: string, ext: 'avif' | 'webp' | 'jpg') =>
  `${prefix}/${base}-640.${ext} 640w, ${prefix}/${base}-1280.${ext} 1280w, ${prefix}/${base}.${ext} 1920w`;
---

<picture class="home-hero" data-hero data-images={JSON.stringify(images)} data-prefix={prefix}>
  <source srcset={buildSet(images[0], 'avif')} sizes="100vw" type="image/avif" data-source="avif" />
  <source srcset={buildSet(images[0], 'webp')} sizes="100vw" type="image/webp" data-source="webp" />
  <img
    src={`${prefix}/${images[0]}.jpg`}
    srcset={buildSet(images[0], 'jpg')}
    sizes="100vw"
    alt={home.imageAlt || ''}
    loading="eager"
    fetchpriority="high"
    class="home-bg-img"
  />
</picture>

<script>
  // Cycle the home hero through its image set, every 5 s.
  // Mirrors src/routes/home/home.ts cyclePictures saga from CRA.
  const PERIOD_MS = 5000;

  document.querySelectorAll<HTMLPictureElement>('[data-hero]').forEach((picture) => {
    const images: string[] = JSON.parse(picture.dataset.images || '[]');
    const prefix = picture.dataset.prefix || '';
    if (images.length <= 1) return;

    const avifSrc = picture.querySelector<HTMLSourceElement>('[data-source="avif"]');
    const webpSrc = picture.querySelector<HTMLSourceElement>('[data-source="webp"]');
    const img = picture.querySelector<HTMLImageElement>('img');
    if (!avifSrc || !webpSrc || !img) return;

    const buildSet = (base: string, ext: string) =>
      `${prefix}/${base}-640.${ext} 640w, ${prefix}/${base}-1280.${ext} 1280w, ${prefix}/${base}.${ext} 1920w`;

    let i = 0;
    setInterval(() => {
      i = (i + 1) % images.length;
      const base = images[i];
      avifSrc.srcset = buildSet(base, 'avif');
      webpSrc.srcset = buildSet(base, 'webp');
      img.srcset = buildSet(base, 'jpg');
      img.src = `${prefix}/${base}.jpg`;
    }, PERIOD_MS);
  });
</script>
