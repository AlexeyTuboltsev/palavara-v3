---
import { SITE } from '../data/site';

interface Props {
  /** Filename base — e.g. "home-1" generates home-1-640.avif/webp/jpg etc. */
  base: string;
  alt: string;
  className?: string;
}

const { base, alt, className } = Astro.props;
const prefix = SITE.imgPrefix;

// Build srcset strings for each format using the 640/1280/1920 variants
// generated by scripts/generate-hero-variants.js in the CRA repo.
const avifSet = `${prefix}/${base}-640.avif 640w, ${prefix}/${base}-1280.avif 1280w, ${prefix}/${base}.avif 1920w`;
const webpSet = `${prefix}/${base}-640.webp 640w, ${prefix}/${base}-1280.webp 1280w, ${prefix}/${base}.webp 1920w`;
const jpegSet = `${prefix}/${base}-640.jpg 640w, ${prefix}/${base}-1280.jpg 1280w, ${prefix}/${base}.jpg 1920w`;
---

<picture>
  <source srcset={avifSet} sizes="100vw" type="image/avif" />
  <source srcset={webpSet} sizes="100vw" type="image/webp" />
  <img
    src={`${prefix}/${base}.jpg`}
    srcset={jpegSet}
    sizes="100vw"
    alt={alt}
    loading="eager"
    fetchpriority="high"
    class:list={[className]}
  />
</picture>
