---
import { ROUTES, NAV_GROUPS, type RouteKey } from '../data/routes';

interface Props {
  active: RouteKey;
  variant?: 'home' | 'section';
}
const { active, variant = 'section' } = Astro.props;
---

<nav class:list={['palavara-menu', `palavara-menu--${variant}`]} data-menu>
  <button class="palavara-menu__toggle" type="button" aria-controls="palavara-menu-list" aria-expanded="false" data-menu-toggle>
    <span class="palavara-menu__toggle-line"></span>
    <span class="palavara-menu__toggle-line"></span>
    <span class="palavara-menu__toggle-line"></span>
  </button>
  <ul id="palavara-menu-list" class="palavara-menu__list">
    {NAV_GROUPS.map(({label, children}) => (
      <li class="palavara-menu__group">
        {children.length === 1 ? (
          <a href={ROUTES[children[0]].path} class:list={['palavara-menu__link', children[0] === active && 'is-active']}>
            {label}
          </a>
        ) : (
          <>
            <span class="palavara-menu__group-label">{label}</span>
            <ul class="palavara-menu__sublist">
              {children.map((key) => (
                <li>
                  <a href={ROUTES[key].path} class:list={['palavara-menu__link', key === active && 'is-active']}>
                    {ROUTES[key].title.split(' | ')[0].split(' — ')[0]}
                  </a>
                </li>
              ))}
            </ul>
          </>
        )}
      </li>
    ))}
  </ul>
</nav>

<script>
  // Mobile menu toggle — tiny vanilla JS, no framework.
  document.querySelectorAll<HTMLButtonElement>('[data-menu-toggle]').forEach((btn) => {
    btn.addEventListener('click', () => {
      const expanded = btn.getAttribute('aria-expanded') === 'true';
      btn.setAttribute('aria-expanded', expanded ? 'false' : 'true');
      const menu = btn.closest('[data-menu]');
      menu?.classList.toggle('is-open');
    });
  });
</script>

<style>
  .palavara-menu { font-size: 18px; }
  .palavara-menu__toggle {
    display: none;
    background: transparent;
    border: 0;
    padding: 8px;
    cursor: pointer;
    flex-direction: column;
    gap: 4px;
  }
  .palavara-menu__toggle-line {
    display: block;
    width: 24px;
    height: 2px;
    background: currentColor;
  }
  .palavara-menu__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .palavara-menu__group { padding: 4px 0; }
  .palavara-menu__group-label {
    display: block;
    font-weight: 500;
    margin-bottom: 4px;
  }
  .palavara-menu__sublist {
    list-style: none;
    margin: 0;
    padding-left: 16px;
    display: flex;
    flex-direction: column;
    gap: 2px;
    font-size: 16px;
    opacity: 0.85;
  }
  .palavara-menu__link {
    display: inline-block;
    padding: 2px 0;
    text-decoration: none;
  }
  .palavara-menu__link:hover { text-decoration: underline; }
  .palavara-menu__link.is-active { font-weight: 700; text-decoration: underline; }

  @media (max-width: 600px) {
    .palavara-menu__toggle { display: flex; }
    .palavara-menu__list { display: none; }
    .palavara-menu.is-open .palavara-menu__list { display: flex; }
  }
</style>
