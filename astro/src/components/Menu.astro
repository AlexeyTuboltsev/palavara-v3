---
import { ROUTES, type RouteKey } from '../data/routes';
import styles from '../components-styles/Menu.module.scss';
import secondaryStyles from '../components-styles/SectionMenu.module.scss';

interface Props {
  active: RouteKey;
  /** 'blue' = section pages, 'yellow' = about, 'home' = home */
  variant: 'blue' | 'yellow' | 'home';
  /** Whether the menu can collapse on mobile. Home is non-collapsible. */
  collapsible?: boolean;
}
const { active, variant, collapsible = true } = Astro.props;

const menuVariantClass =
  variant === 'home' ? styles.menuHome :
  variant === 'yellow' ? styles.menuYellow : styles.menuBlue;

const itemVariantClass =
  variant === 'home' ? styles.menuYellow : styles.menuBlue;

type Item =
  | { kind: 'simple'; key: RouteKey; label: string }
  | { kind: 'parent'; id: string; label: string; children: { key: RouteKey; label: string }[] };

const ITEMS: Item[] = [
  { kind: 'parent', id: 'classes', label: 'classes', children: [
    { key: 'kidsClass', label: 'kids class' },
    { key: 'wheelThrowing', label: 'wheel-throwing' },
  ]},
  { kind: 'simple', key: 'familySaturday', label: 'family saturday' },
  { kind: 'simple', key: 'openStudio', label: 'open studio' },
  { kind: 'simple', key: 'firingService', label: 'firing service' },
  { kind: 'simple', key: 'giftCertificate', label: 'gift certificate' },
  { kind: 'simple', key: 'membership', label: 'membership' },
  { kind: 'parent', id: 'eventWorkshops', label: 'event workshops', children: [
    { key: 'teamEvents', label: 'team events' },
    { key: 'birthdayParties', label: 'birthday parties' },
  ]},
];

const isParentActive = (children: { key: RouteKey }[]) =>
  children.some((c) => c.key === active);
---

<div class:list={[styles.menu, menuVariantClass]} data-menu data-collapsible={collapsible ? '' : undefined} data-hidden-class={styles.menuHidden}>
  {ITEMS.map((item) => (
    item.kind === 'simple' ? (
      <a
        href={ROUTES[item.key].path}
        class:list={[
          styles.menuItem,
          item.key === active && styles.menuItemActive,
          itemVariantClass,
        ]}
      >{item.label}</a>
    ) : (
      <div
        data-parent={item.id}
        data-active-class={styles.parentMenuItemWrapperActive}
        data-parent-label-active={styles.parentMenuItem}
        data-parent-label-inactive={styles.menuItem}
        class:list={[
          styles.parentMenuItemWrapper,
          isParentActive(item.children) && styles.parentMenuItemWrapperActive,
        ]}
      >
        <div
          data-parent-label
          class:list={[
            isParentActive(item.children) ? styles.parentMenuItem : styles.menuItem,
            itemVariantClass,
          ]}
        >{item.label}<span data-parent-colon>{isParentActive(item.children) ? ':' : ''}</span></div>
        {item.children.map((c) => (
          <a
            data-child-of={item.id}
            href={ROUTES[c.key].path}
            class:list={[
              styles.childMenuItem,
              c.key === active && styles.childMenuItemActive,
              itemVariantClass,
            ]}
          >{c.label}</a>
        ))}
      </div>
    )
  ))}
  {collapsible && (
    <a
      href="/"
      class:list={[styles.menuButton, variant === 'yellow' && styles.menuButtonBlue]}
      aria-label="Toggle menu"
      data-menu-button
    ><span></span><span></span><span></span></a>
  )}
  <div class={secondaryStyles.mobileSecondaryMenu} data-mobile-secondary>
    <a
      href={ROUTES.rentASpace.path}
      class:list={[secondaryStyles.sectionMenuItemSecondary, secondaryStyles.sectionMenuBlue]}
    >rent a space</a>
    <a
      href={ROUTES.contact.path}
      class:list={[secondaryStyles.sectionMenuItemSecondary, secondaryStyles.sectionMenuBlue]}
    >contact</a>
  </div>
</div>

<style>
  /* Children are in the DOM but only shown when their parent wrapper has the active class. */
  [data-child-of] { display: none; }
  [data-menu] [data-parent].is-open [data-child-of],
  [data-menu] [data-parent][class*="parent-menu-item-wrapper-active"] [data-child-of] {
    display: block;
  }
  [data-mobile-secondary] {
    display: none;
  }
  @media (max-width: 500px) {
    [data-mobile-secondary] {
      display: grid;
    }
  }
</style>

<script is:inline>
  (function () {
    function applyHidden() {
      var isMobile = window.matchMedia('(max-width: 500px)').matches;
      var menus = document.querySelectorAll('[data-menu]');
      for (var i = 0; i < menus.length; i++) {
        var menu = menus[i];
        var hiddenClass = menu.getAttribute('data-hidden-class');
        if (!hiddenClass) continue;
        var collapsible = menu.hasAttribute('data-collapsible');
        if (isMobile && collapsible) menu.classList.add(hiddenClass);
        else menu.classList.remove(hiddenClass);
      }
    }
    applyHidden();
    window.addEventListener('resize', applyHidden);

    var buttons = document.querySelectorAll('[data-menu-button]');
    for (var j = 0; j < buttons.length; j++) {
      buttons[j].addEventListener('click', function (e) {
        if (!window.matchMedia('(max-width: 500px)').matches) return;
        e.preventDefault();
        var menu = e.currentTarget.closest('[data-menu]');
        if (!menu) return;
        var hiddenClass = menu.getAttribute('data-hidden-class');
        if (hiddenClass) menu.classList.toggle(hiddenClass);
      });
    }

    // Parent toggle: clicking the parent label toggles `is-open`. The active-class
    // (when a child route is the current page) keeps the children visible regardless.
    var parents = document.querySelectorAll('[data-parent]');
    for (var k = 0; k < parents.length; k++) {
      (function (wrapper) {
        var label = wrapper.querySelector('[data-parent-label]');
        if (!label) return;
        var activeClass = wrapper.getAttribute('data-active-class') || '';
        var labelActiveClass = wrapper.getAttribute('data-parent-label-active') || '';
        var labelInactiveClass = wrapper.getAttribute('data-parent-label-inactive') || '';
        var colon = wrapper.querySelector('[data-parent-colon]');
        label.style.cursor = 'pointer';
        label.addEventListener('click', function () {
          // Don't toggle if a child is active (the current page).
          if (wrapper.classList.contains(activeClass)) return;
          var open = wrapper.classList.toggle('is-open');
          if (labelActiveClass && labelInactiveClass) {
            label.classList.toggle(labelActiveClass, open);
            label.classList.toggle(labelInactiveClass, !open);
          }
          if (colon) colon.textContent = open ? ':' : '';
        });
      })(parents[k]);
    }
  })();
</script>
