---
import BaseLayout from './BaseLayout.astro';
import Logo from '../components/Logo.astro';
import Menu from '../components/Menu.astro';
import SectionHeader from '../components/SectionHeader.astro';
import SectionVisual from '../components/SectionVisual.astro';
import { ROUTES, type RouteKey } from '../data/routes';
import { getManifest } from '../data/imageManifest';
import sectionStyles from '../components-styles/Section.module.scss';
import logoStyles from '../components-styles/Logo.module.scss';

interface Props {
  routeKey: RouteKey;
}
const { routeKey } = Astro.props;
const route = ROUTES[routeKey];
const visualTestMode = process.env.VISUAL_TEST_MODE === 'true';

const mobileLqip = (!visualTestMode && route.heroBase)
  ? (await getManifest())?.images[`${route.heroBase}.jpg`]?.lqip.base64 ?? null
  : null;
---

<BaseLayout
  title={route.title}
  description={route.description}
  canonicalPath={route.path}
  ogImageBase={route.heroBase}
  noindex={route.noindex}
  preloadHeroBase={route.heroBase}
>
  <div class={sectionStyles.sectionContainer}>
    <div class={sectionStyles.header}>
      <a href="/" class:list={[logoStyles.logo, logoStyles.logoBlue]} aria-label="Palavara — home">
        <Logo />
      </a>
      <Menu active={routeKey} variant="blue" />
      <SectionHeader variant="section" active={routeKey} />
    </div>
    <div class={sectionStyles.buttons}>
      {route.images && route.images.length > 1 ? (
        <>
          <svg data-section-prev role="button" aria-label="Previous image" class={sectionStyles.minus} viewBox="0 0 38 1" fill="none" xmlns="http://www.w3.org/2000/svg">
            <line y1="0.5" x2="38" y2="0.5"></line>
          </svg>
          <svg data-section-next role="button" aria-label="Next image" class={sectionStyles.plus} viewBox="0 0 38 38" fill="none" xmlns="http://www.w3.org/2000/svg">
            <line y1="18.5" x2="38" y2="18.5"></line>
            <line x1="19.5" y1="2.18557e-08" x2="19.5" y2="38"></line>
          </svg>
        </>
      ) : null}
    </div>
    <div class={sectionStyles.sectionContent}>
      {route.heroBase ? (
        <div class={sectionStyles.visual}>
          <SectionVisual base={route.heroBase} images={route.images} alt={route.imageAlt || ''} />
        </div>
      ) : null}
      <div class={sectionStyles.textWrapper}>
        <div class={sectionStyles.text}>
          <slot />
        </div>
        {route.heroBase ? (
          <div class={sectionStyles.mobileImage}>
            {visualTestMode ? (
              <div style="background-color:#e0e0e0;width:100%;height:100%;" aria-hidden="true"></div>
            ) : (
              <>
                {mobileLqip && (
                  <img
                    data-mobile-lqip
                    src={mobileLqip}
                    alt=""
                    aria-hidden="true"
                    style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;filter:blur(5px);transition:opacity 1s ease-out;"
                  />
                )}
                <img
                  data-mobile-main
                  src={`https://be.palavara.com/img/studio/${route.heroBase}.jpg`}
                  alt={route.imageAlt || ''}
                  loading="lazy"
                  style="position:relative;width:100%;height:100%;object-fit:cover;"
                />
              </>
            )}
          </div>
        ) : null}
      </div>
    </div>
  </div>
</BaseLayout>

<script is:inline>
  (function () {
    var main = document.querySelector('[data-mobile-main]');
    var lqip = document.querySelector('[data-mobile-lqip]');
    if (!main || !lqip) return;
    function hideLqip() { lqip.style.opacity = '0'; }
    if (main.complete && main.naturalWidth > 0) hideLqip();
    else main.addEventListener('load', hideLqip, { once: true });
  })();
</script>
