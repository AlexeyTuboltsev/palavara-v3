---
import BaseLayout from './BaseLayout.astro';
import Logo from '../components/Logo.astro';
import Menu from '../components/Menu.astro';
import SectionHeader from '../components/SectionHeader.astro';
import SectionVisual from '../components/SectionVisual.astro';
import { ROUTES, type RouteKey } from '../data/routes';
import sectionStyles from '../components-styles/Section.module.scss';
import logoStyles from '../components-styles/Logo.module.scss';

interface Props {
  routeKey: RouteKey;
}
const { routeKey } = Astro.props;
const route = ROUTES[routeKey];
---

<BaseLayout
  title={route.title}
  description={route.description}
  canonicalPath={route.path}
  ogImageBase={route.heroBase}
  noindex={route.noindex}
  preloadHeroBase={route.heroBase}
>
  <div class={sectionStyles.sectionContainer}>
    <div class={sectionStyles.header}>
      <a href="/" class:list={[logoStyles.logo, logoStyles.logoBlue]} aria-label="Palavara — home">
        <Logo />
      </a>
      <Menu active={routeKey} variant="blue" />
      <SectionHeader variant="section" />
    </div>
    <div class={sectionStyles.sectionContent}>
      {route.heroBase ? (
        <div class={sectionStyles.visual}>
          <SectionVisual base={route.heroBase} images={route.images} alt={route.imageAlt || ''} />
        </div>
      ) : null}
      <div class={sectionStyles.textWrapper}>
        <div class={sectionStyles.text}>
          <slot />
        </div>
      </div>
    </div>
  </div>
</BaseLayout>
