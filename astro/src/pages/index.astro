---
import BaseLayout from '../layouts/BaseLayout.astro';
import Logo from '../components/Logo.astro';
import HeaderLinks from '../components/HeaderLinks.astro';
import Menu from '../components/Menu.astro';
import HomeHeroCarousel from '../components/HomeHeroCarousel.astro';
import { ROUTES } from '../data/routes';
import { SITE } from '../data/site';

const route = ROUTES.home;
---

<BaseLayout
  title={route.title}
  description={route.description}
  canonicalPath={route.path}
  ogImageBase="home-1"
  preloadHeroBase="home-1"
  preloadHeroResponsive={true}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "LocalBusiness",
      "@id": `${SITE.url}/#studio`,
      name: "Palavara Pottery Studio",
      alternateName: "Palavara Töpferei und Atelier",
      description: "Pottery studio in Berlin offering wheel throwing classes, kids classes, open studio sessions, memberships, team events, and gift certificates.",
      url: `${SITE.url}/`,
      image: `${SITE.url}/img/home-1.jpg`,
      email: SITE.email,
      address: {
        "@type": "PostalAddress",
        streetAddress: SITE.address.street,
        postalCode: SITE.address.postalCode,
        addressLocality: SITE.address.city,
        addressCountry: SITE.address.country,
      },
      sameAs: [SITE.instagram.studio, SITE.instagram.ceramics],
      founder: { "@type": "Person", name: "Varvara Polyakova" },
      areaServed: { "@type": "City", name: "Berlin" },
    })} />
  </Fragment>

  <div class="home-background">
    <HomeHeroCarousel />
    <div class="home-layout">
      <div class="logo-area"><Logo fill="#ffff00" /></div>
      <div class="links-area"><HeaderLinks /></div>
      <h1 class="title">Pottery classes<br/>for kids and adults</h1>
      <div class="menu-area"><Menu active="home" variant="home" /></div>
      <aside class="announcement">
        <a href="/membership">
          Pottery studio membership<br/>
          <span class="underline">available!</span>&nbsp;→
        </a>
      </aside>
    </div>
  </div>
</BaseLayout>
