# Sentry DSN for error tracking
REACT_APP_SENTRY=https://your-sentry-dsn-here

# CDN prefix for images
REACT_APP_IMG_PREFIX=https://data.palavara.com/img/studio

# Enable optimized images (AVIF/WebP/JPEG with responsive variants)
# Set to 'true' to use optimized images from manifest
# Set to 'false' to use legacy blob-based image loading
REACT_APP_USE_OPTIMIZED_IMAGES=false
