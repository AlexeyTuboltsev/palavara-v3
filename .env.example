# Sentry DSN for error tracking
REACT_APP_SENTRY=https://your-sentry-dsn-here

# CDN prefix for images
REACT_APP_IMG_PREFIX=https://be.palavara.com/img/studio

# Enable optimized images (AVIF/WebP/JPEG with responsive variants)
# Set to 'true' to use optimized images from manifest (recommended)
REACT_APP_USE_OPTIMIZED_IMAGES=true
