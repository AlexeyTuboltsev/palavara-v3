# Copy to .env and fill in. Used only for local `sam local` testing.
# Never commit .env with real credentials.

PAYPAL_CLIENT_ID=YOUR_SANDBOX_CLIENT_ID_HERE
PAYPAL_CLIENT_SECRET=YOUR_SANDBOX_CLIENT_SECRET_HERE
PAYPAL_MODE=sandbox
PAYPAL_RETURN_URL=http://localhost:8080/confirm.html
PAYPAL_CANCEL_URL=http://localhost:8080/index.html
PAYPAL_IPN_VERIFY_URL=https://ipnpb.sandbox.paypal.com/cgi-bin/webscr
PRICE_CENTS=2000
PRICE_CURRENCY=EUR
